---
import Layout from '../layouts/Layout.astro';
---
<Layout title="ページが見つかりません">
  <section style="padding: 12rem 1.5rem 6rem; text-align: center;">
    <h1 style="font-size: 4rem; font-weight: 700; color: #92400e; margin-bottom: 1rem;">404</h1>
    <p style="font-size: 1.1rem; color: var(--color-sub); margin-bottom: 2rem;">お探しのページが見つかりませんでした。</p>
    <a href="/" style="display: inline-block; padding: 0.8rem 2rem; background: #92400e; color: white; font-size: 0.9rem; font-weight: 600; text-decoration: none;">トップページへ戻る</a>
  </section>
</Layout>
